@model GameJamApp.Models.Jugador

<div class="container mt-4">
    <h2>Registro GameJam 2026</h2>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-@ViewBag.Status">
            @ViewBag.Mensaje
        </div>
    }

    <form asp-action="Registro" method="post" class="card p-4 shadow-sm">
        <div class="mb-3">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="FechaNacimiento" class="form-label"></label>
            <input asp-for="FechaNacimiento" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="hobbies" class="form-label">Hobbies (Separados por coma)</label>
            <textarea asp-for="hobbies" class="form-control"></textarea>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="PagoMatricula" class="form-check-input" />
            <label asp-for="PagoMatricula" class="form-check-label"></label>
        </div>

        <button type="submit" class="btn btn-primary">Registrar</button>
    </form>
</div>